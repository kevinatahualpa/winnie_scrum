actor "Jefe de Proyecto" as jefe_proyecto
actor "Miembro" as miembro
actor "Usuario no\nautenticado" as no_auth

' Herencia de roles (de mayor a menor permiso)
super_admin <|-- admin : hereda
admin <|-- jefe_area : hereda
jefe_area <|-- jefe_proyecto : hereda
jefe_proyecto <|-- miembro : hereda

