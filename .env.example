# ============================================
# Winnie - Environment Variables Example
# Copy this file to .env and fill in real values
# ============================================

# Django
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-random-50-char-string

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=winnie_db
DB_USER=winnie_user
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432

# Email via Resend (recomended para produccion)
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=Winnie <noreply@resend.dev>
# Cuando tengas dominio propio, cambia DEFAULT_FROM_EMAIL y verifica el dominio en Resend

# Cloudflare R2 Storage (S3-compatible)
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=winnie-media-bucket
R2_PUBLIC_URL=https://pub-your-account-id.r2.dev
